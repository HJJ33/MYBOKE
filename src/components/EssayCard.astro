---
import type { Essay } from "../lib/essays";
import { formatDate, getReadingTime } from "../lib/essays";
import TagList from "./TagList.astro";

interface Props {
  essay: Essay;
}

const { essay } = Astro.props;
const readingTime = getReadingTime(essay);
---

<article class="surface-card essay-card">
  <a class="essay-card-link" href={`/essays/${essay.id}/`} aria-label={`阅读：${essay.data.title}`}></a>
  <div class="meta">
    <time datetime={essay.data.pubDate.toISOString()}>{formatDate(essay.data.pubDate)}</time>
    <span aria-hidden="true"> · </span>
    <span>{readingTime} 分钟阅读</span>
  </div>
  <h2>{essay.data.title}</h2>
  <p>{essay.data.description}</p>
  <TagList tags={essay.data.tags} />
</article>
