---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "首页" },
  { href: "/archive/", label: "归档" },
  { href: "/tags/", label: "标签" },
  { href: "/about/", label: "关于" },
];
---

<header class="site-header">
  <a class="site-name" href="/">古月随笔</a>
  <nav aria-label="主导航" class="site-nav">
    {
      links.map((link) => (
        <a href={link.href} aria-current={currentPath === link.href ? "page" : undefined}>
          {link.label}
        </a>
      ))
    }
  </nav>
</header>
